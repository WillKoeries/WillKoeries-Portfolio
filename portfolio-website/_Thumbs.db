/* Basic Reset */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Open Sans', sans-serif;
    line-height: 1.6;
}

/* Navigation Bar */
header {
    position: fixed;
    top: 0;
    width: 100%;
    background: rgba(0, 0, 0, 0.7);
    color: #fff;
    z-index: 1000;
    padding: 10px 0;
}

nav ul {
    display: flex;
    justify-content: center;
}

nav ul li {
    list-style: none;
    margin: 0 15px;
}





nav ul li a {
    color: #fff;
    text-decoration: none;
    font-size: 18px;
}

nav ul li a:hover {
    text-decoration: underline;
}

/* Hero Section (Static Background) */
.hero {
    height: 100vh;
    background: url('pp.jpg') no-repeat center center/cover;
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
    color: #fff;
}

.hero-content h1 {
    font-size: 48px;
    margin-bottom: 20px;
}

.hero-content p {
    font-size: 24px;
    margin-bottom: 30px;
}

.cta-button {
    background-color: #00b4d8;
    padding: 10px 20px;
    color: #fff;
    text-decoration: none;
    border-radius: 5px;
    font-size: 20px;
}

.cta-button:hover {
    background-color: #0077b6;
}

/* Skills Section */
.skills {
    padding: 50px 20px;
    text-align: center;
    background-color: #f4f4f4;
}

.skills h2 {
    font-size: 36px;
    margin-bottom: 40px;
}

.skill-cards {
    display: flex;
    justify-content: center;
    gap: 30px;
}

.card {
    background-color: #fff;
    padding: 20px;
    border-radius: 10px;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    width: 300px;
}

.card h3 {
    margin-bottom: 10px;
    font-size: 24px;
}

/* Parallax Effect */
.parallax {
    position: relative;
    background-attachment: fixed;
    background-size: cover;
    background-position: center;
    height: 100vh;
}

.parallax-2 {
    background-image: url('hero.jpg'); /* Replace with your second image */
}

/* Ensure content on top of parallax */
.parallax-content {
    position: relative;
    z-index: 10;
    text-align: center;
    color: #fff;
}

.parallax-content h2 {
    font-size: 36px;
    padding: 50px 0;
}



/* Portfolio Section */
.portfolio {
    padding: 100px 20px; /* Padding for fixed navbar */
    background-color: #f4f4f4;
    text-align: center;
}

.portfolio h2 {
    font-size: 36px;
    margin-bottom: 40px;
}

.portfolio-grid {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 30px; /* Space between project cards */
}

.portfolio-item {
    background-color: #fff;
    padding: 20px;
    border-radius: 10px;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    width: 300px; /* Fixed width for each project card */
    text-align: left;
    margin-bottom: 20px; /* Margin to ensure spacing below each card */
}

.portfolio-item h3 {
    margin-bottom: 10px;
    font-size: 24px;
}

.portfolio-item p {
    margin-bottom: 10px;
    font-size: 16px;
}

.portfolio-item img {
    width: 100%; /* Ensure image fills the width of the card */
    height: auto;
    border-radius: 8px; /* Rounded corners for images */
    margin-top: 10px;
}



/* About Section */
.about {
    padding: 100px 20px;
    background: url('bb.jpg') no-repeat center center/cover; /* Add background image */
    background-attachment: fixed; /* Parallax effect for background */
    color: #fff; /* White text to contrast with background */
    text-align: center;
}

.about-header {
    margin-bottom: 40px;
}

.about h2 {
    font-size: 36px;
    margin-bottom: 20px;
    color: #fff;
}

.divider {
    width: 100px;
    height: 3px;
    background-color: #fff;
    border: none;
    margin: 0 auto 20px;
}

.about-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 40px;
}

.about-text {
    max-width: 600px;
    margin: auto;
    font-size: 18px;
    line-height: 1.8;
    text-align: left;
    background-color: rgba(0, 0, 0, 0.7); /* Semi-transparent background */
    padding: 30px;
    border-radius: 15px;
    box-shadow: 0 10px 15px rgba(0, 0, 0, 0.1);
    color: #fff;
}

.about-text p {
    margin-bottom: 20px;
}

.about-image {
    max-width: 350px;
    margin-top: 20px;
}

.about-image img {
    width: 100%;
    height: auto;
    border-radius: 10px;
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15);
}

/* Footer */
footer {
    text-align: center;
    padding: 20px;
    background-color: #333;
    color: #fff;
}




/* Basic Reset */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Open Sans', sans-serif;
    line-height: 1.6;
}

/* Navigation Bar */
header {
    position: fixed;
    top: 0;
    width: 100%;
    background: rgba(0, 0, 0, 0.7);
    color: #fff;
    z-index: 1000;
    padding: 10px 0;
}

nav ul {
    display: flex;
    justify-content: center;
}

nav ul li {
    list-style: none;
    margin: 0 15px;
}

nav ul li a {
    color: #fff;
    text-decoration: none;
    font-size: 18px;
}

nav ul li a:hover {
    text-decoration: underline;
}
/* Contact Section */
.contact {
    padding: 100px 20px;
    background-color: #fff;
    text-align: center;
    background: linear-gradient(135deg, #00b4d8, #0077b6);
    color: white;
}

.contact-header {
    margin-bottom: 40px;
}

.contact h2 {
    font-size: 36px;
    color: white;
}

.divider {
    width: 100px;
    height: 3px;
    background-color: #fff;
    border: none;
    margin: 0 auto 20px;
}

.contact p {
    font-size: 18px;
    margin-bottom: 40px;
}

.contact-form {
    display: flex;
    justify-content: center;
}

form {
    max-width: 500px;
    width: 100%;
    background-color: #fff;
    padding: 30px;
    border-radius: 15px;
    box-shadow: 0 10px 15px rgba(0, 0, 0, 0.1);
}

.form-group {
    margin-bottom: 20px;
    text-align: left;
}

.form-group label {
    display: block;
    margin-bottom: 5px;
    font-size: 16px;
    color: #333;
}

.form-group input, .form-group textarea {
    width: 100%;
    padding: 10px;
    border: 1px solid #ccc;
    border-radius: 5px;
    font-size: 16px;
}

.submit-btn {
    width: 100%;
    padding: 12px;
    background-color: #0077b6;
    color: white;
    border: none;
    border-radius: 5px;
    font-size: 18px;
    cursor: pointer;
    transition: background-color 0.3s;
}

.submit-btn:hover {
    background-color: #005f99;
}

/* Social Icons Section */
.social-icons {
    margin-top: 40px;
}

.social-icons p {
    font-size: 18px;
}

.social-icons a {
    margin: 0 10px;
    display: inline-block;
}

.social-icons img {
    width: 40px;
    height: 40px;
    transition: transform 0.3s ease;
}

.social-icons a:hover img {
    transform: scale(1.1); /* Zoom on hover */
}

/* Footer */
footer {
    text-align: center;
    padding: 20px;
    background-color: #333;
    color: #fff;
}


