<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Will's Portfolio</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <header>
        <nav>
            <ul>
                <li><a href="#home">Home</a></li>
                <li><a href="portfolio.html">Portfolio</a></li>
                <li><a href="#about">About</a></li>
                <li><a href="#contact">Contact</a></li>
            </ul>
        </nav>
    </header>

    <!-- Hero Section with Static Background -->
    <section id="home" class="hero">
        <div class="hero-content">
            <h1>Hello! I'm Will Koeries</h1>
            <p>An IT Student with a passion for technology and problem-solving.</p>
            <a href="portfolio.html" class="cta-button">See My Work</a>
        </div>
    </section>

    <!-- Skills Section -->
    <section id="skills" class="skills">
        <h2>My Skills</h2>
        <div class="skill-cards">
            <div class="card">
                <h3>Programming Languages</h3>
                <p>HTML, CSS, JavaScript, Python</p>
            </div>
            <div class="card">
                <h3>Web Development</h3>
                <p>Frontend & Backend Development</p>
            </div>
            <div class="card">
                <h3>Networking & IT Support</h3>
                <p>Network Troubleshooting & IT Support</p>
            </div>
        </div>
    </section>

    <!-- Parallax Section -->
    <section class="parallax parallax-2">
        <div class="parallax-content">
            <h2>Driven by Passion for Tech</h2>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <p>© 2024 Will Koeries's Portfolio. All Rights Reserved.</p>
    </footer>
</body>
</html>
