<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Will's Portfolio - Projects</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <header>
        <nav>
            <ul>
                <li><a href="index.html">Home</a></li>
                <li><a href="portfolio.html">Portfolio</a></li>
                <li><a href="about.html">About</a></li>
                <li><a href="contact.html">Contact</a></li>
            </ul>
        </nav>
    </header>

    <!-- Portfolio Page Content -->
    <section id="portfolio" class="portfolio">
        <h2>My Projects</h2>
        <div class="portfolio-grid">
            <!-- Project 1 -->
            <div class="portfolio-item">
                <h3>Project 1: Personal Portfolio Website</h3>
                <p>A personal portfolio website showcasing my work, built using HTML, CSS, and JavaScript.</p>
                <p><strong>Technologies:</strong> HTML, CSS, JavaScript</p>
                <img src="p1.jpg" alt="Personal Portfolio Website">
            </div>

            <!-- Project 2 -->
            <div class="portfolio-item">
                <h3>Project 2: E-Commerce Platform</h3>
                <p>An e-commerce platform with cart, checkout, and payment integration.</p>
                <p><strong>Technologies:</strong> Python (Flask), HTML, CSS, JavaScript</p>
                <img src="p2.jpg" alt="E-Commerce Platform">
            </div>

            <!-- Project 3 -->
            <div class="portfolio-item">
                <h3>Project 3: Network Troubleshooting Tool</h3>
                <p>A tool for diagnosing network issues and generating reports.</p>
                <p><strong>Technologies:</strong> Python, Bash</p>
                <img src="p3.jpg" alt="Network Troubleshooting Tool">
            </div>

            <!-- Project 4 -->
            <div class="portfolio-item">
                <h3>Personal Project : Blogging Platform</h3>
                <p>A full blogging platform with user authentication and CRUD functionality.</p>
                <p><strong>Technologies:</strong> Python, HTML, CSS, JavaScript</p>
                <img src="p4.jpg" alt="Blogging Platform">
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <p>© 2024 Will Koeries's Portfolio. All Rights Reserved.</p>
    </footer>
</body>
</html>
